# Copie para .env: npm run setup  (ou: cp .env.example .env)

# Quantidade máxima de convites processados por execução
MAX_INVITES=5

# Intervalo (ms) entre cada convite — aumente se o LinkedIn limitar ações
DELAY_MS=5000

# Mensagem opcional (sobrescreve message.ts). Use \n para quebras de linha.
# Para aspas no texto, envolva o valor em aspas simples: LINKEDIN_MESSAGE='... com "quero". ...'
# LINKEDIN_MESSAGE='Olá! Obrigado por se conectar.\n\nAbs,\nSeu Nome'

# Google Forms - URL do formulário
GOOGLE_FORM_URL=

# Executar em modo headless (sem interface gráfica)
HEADLESS=false
